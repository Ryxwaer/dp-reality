# Only secrets and per-deployment credentials live here.
# Non-secret tuning knobs (intervals, page counts, SMTP host/port, From
# address, base URL, batch window) are baked into compose.yml and overridden
# in compose.dev.yml when they differ in dev.

# MongoDB (external) — full URI with embedded credentials
MONGODB_URI=mongodb://admin:password@host:27017/dp-reality?authSource=admin

# RabbitMQ broker credentials (managed by compose). Change from `guest` in
# production.
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# SMTP login + password. The host/port/from-address are hardcoded in
# compose.yml.
MAIL_SMTP_LOGIN=
MAIL_SMTP_PASSWORD=

# Shared HMAC secret used to sign unsubscribe tokens. MUST match between
# the notification service (signs links inside emails) and the frontend
# (verifies + resigns on POST from the unsubscribe page). Rotate both at
# the same time.
UNSUBSCRIBE_SECRET=change-me-dev-secret-please-rotate-in-prod

# nuxt-auth-utils seals session cookies with this key. MUST be at least
# 32 characters. Changing it invalidates every existing session.
# Generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=change-me-dev-session-password-at-least-32-chars

# Frontend -> RabbitMQ connection. The docker-compose service overrides this
# to point at the in-network rabbitmq host; only relevant when running
# services/frontend outside compose (e.g. `pnpm dev`).
NUXT_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
