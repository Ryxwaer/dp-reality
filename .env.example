# MongoDB (external)
MONGODB_URI=mongodb://admin:password@host:27017/dp-reality?authSource=admin

# RabbitMQ (managed by compose)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Email (SMTP via Mailgun or similar)
MAIL_SMTP_SERVER=smtp.eu.mailgun.org
MAIL_SMTP_PORT=587
MAIL_SMTP_LOGIN=
MAIL_SMTP_PASSWORD=
MAIL_FROM_EMAIL=noreply@yourdomain.com

# App
APP_BASE_URL=http://localhost:3000

# Scraper settings
BAZOS_INTERVAL=5
BAZOS_PAGES=5
SREALITY_INTERVAL=10
SREALITY_PAGES=3
