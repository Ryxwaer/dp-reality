# Everything in this file is optional. compose.yml ships with sensible
# defaults so the stack boots end-to-end with no .env at all.
# Copy to .env only when you want to override something.

# MongoDB connection. Defaults to the in-compose mongo:27017 instance.
# MONGODB_URI=mongodb://mongo:27017/dp-reality

# RabbitMQ broker credentials (managed by compose). Change from `guest`
# for any non-local deployment.
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest

# SMTP credentials for the email-notifier service. Leave unset and no
# emails will be sent (the rest of the app works fine without them).
# MAIL_SMTP_SERVER=
# MAIL_SMTP_LOGIN=
# MAIL_SMTP_PASSWORD=
# MAIL_FROM_EMAIL=
# MAIL_ALLOWED_RECIPIENT_DOMAINS=

# Shared HMAC secret used to sign unsubscribe tokens. Rotate for prod.
# UNSUBSCRIBE_SECRET=change-me-dev-secret-please-rotate-in-prod
