FROM oven/bun:1-alpine

WORKDIR /app

# Install deps first (without postinstall) so the layer is reusable across
# source changes. `bun run dev` regenerates the .nuxt prepare artefacts on
# startup, so skipping the postinstall here is safe.
COPY services/frontend/package.json services/frontend/bun.lock ./
RUN bun install --frozen-lockfile --ignore-scripts

COPY services/frontend/ ./

ENV NODE_ENV=development
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NITRO_HOST=0.0.0.0
ENV NITRO_PORT=3000

EXPOSE 3000

# `bunfig.toml` declares `otel-init.mjs` as a preload, which is how
# bun's bundler / runtime can patch Node's module loader BEFORE the
# Nuxt/Nitro bundle imports `node:http`, `h3`, `mongodb`, `amqplib`,
# etc.; without that the OpenTelemetry auto-instrumentations never
# get a chance to wrap them.
CMD ["bun", "run", "dev"]
