FROM node:22-alpine

WORKDIR /app

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable

# Install deps first (without postinstall) so the layer is reusable across
# source changes. `nuxt dev` regenerates the .nuxt prepare artefacts on
# startup, so skipping the postinstall here is safe.
COPY services/frontend/package.json services/frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile --ignore-scripts

COPY services/frontend/ ./

ENV NODE_ENV=development
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NITRO_HOST=0.0.0.0
ENV NITRO_PORT=3000

EXPOSE 3000

CMD ["pnpm", "dev"]
